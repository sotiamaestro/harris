{
  "name": "harris-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run -c vitest.config.integration.ts",
    "lint": "biome lint packages examples",
    "format": "biome format --write packages examples"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^20.17.6",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4",
    "@harris/core": "workspace:*",
    "@harris/codebase": "workspace:*",
    "@harris/gemini": "workspace:*",
    "@harris/orchestrator": "workspace:*"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1"
  }
}
